{
  "name": "nve-genome-explorer",
  "displayName": "NVE Genome Explorer",
  "description": "Sidebar: Failure Genome, SkillGraph, 5-axis audit, replay gate, skill search, nve-serve bridge",
  "version": "0.3.0",
  "publisher": "creanlab",
  "engines": { "vscode": "^1.85.0" },
  "categories": ["Other"],
  "activationEvents": ["workspaceContains:.evolution/failure_genomes"],
  "main": "./extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "nve-genome",
          "title": "NVE Genome",
          "icon": "$(beaker)"
        }
      ]
    },
    "views": {
      "nve-genome": [
        { "id": "nveAuditScore", "name": "5-Axis Audit" },
        { "id": "nveGenomeFamilies", "name": "Genome Families" },
        { "id": "nveReplayGate", "name": "Replay Gate" },
        { "id": "nveSkillRegistry", "name": "Skill Registry" },
        { "id": "nveSkillPackages", "name": "Skill Packages" },
        { "id": "nveQuickActions", "name": "Quick Actions" },
        { "id": "nveBridgeStatus", "name": "Bridge Status" },
        { "id": "nveMemoryTree", "name": "Memory Layers" }
      ]
    },
    "commands": [
      { "command": "nve.runAudit", "title": "NVE: Run 5-Axis Audit" },
      { "command": "nve.runDistill", "title": "NVE: Distill Genomes" },
      { "command": "nve.runReplay", "title": "NVE: Run Replay Gate" },
      { "command": "nve.runPack", "title": "NVE: Export Pack" },
      { "command": "nve.runSkillExtract", "title": "NVE: Extract Skills" },
      { "command": "nve.runSkillIndex", "title": "NVE: Index Skills" },
      { "command": "nve.runSkillPackage", "title": "NVE: Package Skills" },
      { "command": "nve.runSkillSearch", "title": "NVE: Search Skills" },
      { "command": "nve.refreshAll", "title": "NVE: Refresh All" },
      { "command": "nve.startServer", "title": "NVE: Start Server (nve-serve)" },
      { "command": "nve.bridgeStatus", "title": "NVE: Show Bridge Status" },
      { "command": "nve.runDoctor", "title": "NVE: Run Doctor" },
      { "command": "nve.runSelfCheck", "title": "NVE: Run Self-Check" },
      { "command": "nve.runReport", "title": "NVE: Generate Report" }
    ]
  }
}
