{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://creanlab.com/schemas/failure-genome.schema.json",
  "title": "FailureGenome",
  "description": "A verified genome unit. kind=failure (default, backward-compatible), success, or strategy.",
  "type": "object",
  "required": [
    "genome_id",
    "created_at",
    "incident_id",
    "family",
    "utility",
    "replay"
  ],
  "properties": {
    "genome_id": {
      "type": "string",
      "pattern": "^(FG|SG|TG)-[0-9]{6}$",
      "description": "FG=failure, SG=success, TG=strategy genome"
    },
    "kind": {
      "type": "string",
      "enum": ["failure", "success", "strategy"],
      "default": "failure",
      "description": "Genome kind. failure=what went wrong; success=what works stably; strategy=general reusable tactic"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "incident_id": {
      "type": "string"
    },
    "context_fingerprint": {
      "type": "object",
      "properties": {
        "stack_tags": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "surface_tags": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "environment_tags": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "repo_maturity": {
          "type": "string",
          "enum": [
            "greenfield",
            "legacy",
            "hybrid",
            "unknown"
          ],
          "default": "unknown"
        }
      },
      "additionalProperties": false,
      "default": {}
    },
    "family": {
      "type": "string",
      "minLength": 3
    },
    "violated_invariant": {
      "type": "string",
      "minLength": 3,
      "description": "For failure genomes: which invariant was violated"
    },
    "repair_operator": {
      "type": "string",
      "minLength": 3,
      "description": "For failure genomes: how to repair the violation"
    },
    "success_pattern": {
      "type": ["string", "null"],
      "description": "For success/strategy genomes: the generalized pattern that works stably",
      "default": null
    },
    "applicability": {
      "type": ["string", "null"],
      "description": "For success/strategy genomes: when/where this pattern applies",
      "default": null
    },
    "adversarial_review": {
      "type": ["object", "null"],
      "description": "Critic agent review before promotion (M.2)",
      "properties": {
        "reviewer": { "type": "string" },
        "verdict": { "type": "string", "enum": ["approve", "reject", "revise"] },
        "critique": { "type": "string" },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "reviewed_at": { "type": "string", "format": "date-time" }
      },
      "additionalProperties": false,
      "default": null
    },
    "verifier_evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "kind",
          "ref"
        ],
        "properties": {
          "kind": {
            "type": "string",
            "enum": [
              "test",
              "command_output",
              "screenshot",
              "healthcheck",
              "diff",
              "replay_report",
              "other"
            ]
          },
          "ref": {
            "type": "string"
          },
          "summary": {
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "default": []
    },
    "transferability_tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "utility": {
      "type": "object",
      "required": [
        "score"
      ],
      "properties": {
        "score": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "reuse_count": {
          "type": "integer",
          "minimum": 0,
          "default": 0
        },
        "prevention_count": {
          "type": "integer",
          "minimum": 0,
          "default": 0
        },
        "negative_transfer_count": {
          "type": "integer",
          "minimum": 0,
          "default": 0
        },
        "last_used_at": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        }
      },
      "additionalProperties": false
    },
    "replay": {
      "type": "object",
      "required": [
        "status"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "not_run",
            "passed",
            "failed",
            "partial"
          ]
        },
        "family_sample_size": {
          "type": "integer",
          "minimum": 0,
          "default": 0
        },
        "holdout_sample_size": {
          "type": "integer",
          "minimum": 0,
          "default": 0
        },
        "pass_rate": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "notes": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "proposed_patch_types": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "rule_patch",
          "workflow_patch",
          "skill_patch",
          "verifier_patch",
          "doc_patch"
        ]
      },
      "default": []
    },
    "promotion_decision": {
      "type": "string",
      "enum": [
        "pending",
        "promoted",
        "rejected"
      ],
      "default": "pending"
    },
    "notes": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
