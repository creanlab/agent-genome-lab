{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Skill Relation",
  "type": "object",
  "required": [
    "source_skill_id",
    "relation_type",
    "target"
  ],
  "properties": {
    "source_skill_id": {
      "type": "string"
    },
    "relation_type": {
      "type": "string"
    },
    "target": {
      "type": "string"
    },
    "weight": {
      "type": [
        "number",
        "null"
      ]
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": true
}
