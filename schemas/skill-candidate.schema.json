{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Skill Candidate",
  "type": "object",
  "required": [
    "schema_version",
    "skill_id",
    "title",
    "summary",
    "status",
    "category",
    "source_type",
    "source_ids",
    "steps"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "skill_id": {
      "type": "string",
      "pattern": "^SK-[0-9]{6}$"
    },
    "created_at": {
      "type": [
        "string",
        "null"
      ]
    },
    "updated_at": {
      "type": [
        "string",
        "null"
      ]
    },
    "title": {
      "type": "string"
    },
    "summary": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "candidate",
        "quarantined",
        "admitted",
        "rejected"
      ]
    },
    "category": {
      "type": "string"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "source_type": {
      "type": "string",
      "enum": [
        "failure_genome",
        "experience_unit",
        "manual"
      ]
    },
    "source_ids": {
      "type": "object"
    },
    "triggers": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "when_to_use": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "when_not_to_use": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "inputs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "steps": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "title",
          "instruction",
          "expected_output"
        ],
        "properties": {
          "title": {
            "type": "string"
          },
          "instruction": {
            "type": "string"
          },
          "expected_output": {
            "type": "string"
          },
          "risk": {
            "type": [
              "string",
              "null"
            ]
          }
        },
        "additionalProperties": true
      }
    },
    "success_signals": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "failure_modes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "safety_notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "maintainability_notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "cost_notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "relations": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "evaluation": {
      "type": [
        "object",
        "null"
      ]
    },
    "canonical_hash": {
      "type": [
        "string",
        "null"
      ]
    },
    "semantic_fingerprint": {
      "type": [
        "string",
        "null"
      ]
    },
    "duplicate_of": {
      "type": [
        "string",
        "null"
      ]
    },
    "published_skill_path": {
      "type": [
        "string",
        "null"
      ]
    }
  },
  "additionalProperties": true
}
